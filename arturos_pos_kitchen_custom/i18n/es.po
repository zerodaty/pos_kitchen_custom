#. module: arturos_pos_kitchen_custom
#: model:ir.model.fields,field_description:arturos_pos_kitchen_custom.field_pos_preparation_display_display__enable_auto_send_on_payment
msgid "Auto-send to KDS on Payment"
msgstr "Auto-enviar a KDS al Pagar"

#. module: arturos_pos_kitchen_custom
#: model:ir.model.fields,help:arturos_pos_kitchen_custom.field_pos_preparation_display_display__enable_auto_send_on_payment
msgid "When enabled, orders are automatically sent to KDS upon payment completion instead of requiring the Order button."
msgstr "Cuando está habilitado, las órdenes se envían automáticamente al KDS al completar el pago sin necesidad de presionar el botón Orden."

#. module: arturos_pos_kitchen_custom
#: model:ir.model.fields,field_description:arturos_pos_kitchen_custom.field_pos_preparation_display_display__show_empty_columns
msgid "Show Empty Columns"
msgstr "Mostrar Columnas Vacías"

#. module: arturos_pos_kitchen_custom
#: model:ir.model.fields,help:arturos_pos_kitchen_custom.field_pos_preparation_display_display__show_empty_columns
msgid "When enabled, columns for all configured POS configs are always visible, even if they have no orders. When disabled, only columns with active orders are shown."
msgstr "Cuando está habilitado, las columnas para todas las configuraciones POS se muestran siempre, incluso si no tienen órdenes. Cuando está deshabilitado, solo se muestran las columnas con órdenes activas."

