<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="product_template_form_view_inherit_kds" model="ir.ui.view">
        <field name="name">product.template.form.inherit.kds</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <!-- Add field in General Information tab, after type field -->
            <xpath expr="//field[@name='type']" position="after">
                <field name="special_product_type"/>
            </xpath>
        </field>
    </record>
</odoo>
