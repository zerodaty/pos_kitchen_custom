<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.arturos.pos.kitchen</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//setting[field[@name='pos_module_pos_restaurant']]" position="after">
                <setting string="Enable KDS Only Mode" help="Hides Table Management UI and unblocks the Order button for Kitchen Display System usage.">
                    <field name="pos_enable_kds_only" readonly="pos_has_active_session"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>